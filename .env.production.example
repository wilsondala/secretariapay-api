# ==========================================================
# SecretáriaPay API - Produção Hostinger
# Copie para .env.production no servidor.
# Nunca commitar .env.production real.
# ==========================================================

SERVER_PORT=8080

POSTGRES_DB=secretariapay_db
POSTGRES_USER=secretariapay_user
POSTGRES_PASSWORD=troque_essa_senha_forte

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/secretariapay_db
SPRING_DATASOURCE_USERNAME=secretariapay_user
SPRING_DATASOURCE_PASSWORD=troque_essa_senha_forte

APP_SECURITY_JWT_SECRET=troque_para_um_jwt_secret_grande_e_forte_em_producao_com_mais_de_64_caracteres
APP_SECURITY_JWT_EXPIRATION_MINUTES=1440

# Recuperação controlada e criação dos usuários de teste.
# Ative somente durante a inicialização necessária e volte para false em seguida.
SECRETARIAPAY_TEST_USERS_ENABLED=false
SECRETARIAPAY_TEST_USERS_PASSWORD=Admin@123456

SECRETARIAPAY_WHATSAPP_VERIFY_TOKEN=SecretariaPay-dev-token

# Primeiro deixamos false na VPS até validar healthcheck e webhook.
SECRETARIAPAY_WHATSAPP_ENABLED=false

# Depois preencheremos com os dados reais da Meta.
SECRETARIAPAY_WHATSAPP_PHONE_NUMBER_ID=1052082687989232
SECRETARIAPAY_WHATSAPP_ACCESS_TOKEN=
SECRETARIAPAY_WHATSAPP_GRAPH_API_VERSION=v25.0
SECRETARIAPAY_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com


SECRETARIAPAY_EMAIL_ENABLED=true
SECRETARIAPAY_EMAIL_FROM=dcr_pay@imetroangola.com
SECRETARIAPAY_EMAIL_CC=df.oi_pay@imetroangola.com

SECRETARIAPAY_SMS_ENABLED=false
SECRETARIAPAY_SMS_PROVIDER=MOCK
SECRETARIAPAY_SMS_API_URL=
SECRETARIAPAY_SMS_API_TOKEN=
