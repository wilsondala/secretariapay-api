# ==========================================================
# VaiRápido API - Produção Hostinger
# Copie para .env.production no servidor.
# Nunca commitar .env.production real.
# ==========================================================

SERVER_PORT=8080

POSTGRES_DB=vairapido_db
POSTGRES_USER=vairapido_user
POSTGRES_PASSWORD=troque_essa_senha_forte

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/vairapido_db
SPRING_DATASOURCE_USERNAME=vairapido_user
SPRING_DATASOURCE_PASSWORD=troque_essa_senha_forte

APP_SECURITY_JWT_SECRET=troque_para_um_jwt_secret_grande_e_forte_em_producao_com_mais_de_64_caracteres
APP_SECURITY_JWT_EXPIRATION_MINUTES=1440

VAIRAPIDO_WHATSAPP_VERIFY_TOKEN=vairapido-dev-token

# Primeiro deixamos false na VPS até validar healthcheck e webhook.
VAIRAPIDO_WHATSAPP_ENABLED=false

# Depois preencheremos com os dados reais da Meta.
VAIRAPIDO_WHATSAPP_PHONE_NUMBER_ID=1052082687989232
VAIRAPIDO_WHATSAPP_ACCESS_TOKEN=
VAIRAPIDO_WHATSAPP_GRAPH_API_VERSION=v25.0
VAIRAPIDO_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
