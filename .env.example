# ==========================================================
# SecretáriaPay API - Exemplo de variáveis de ambiente
# Copie este arquivo para .env e ajuste localmente.
# Nunca coloque tokens reais no Git.
# ==========================================================

# Servidor
SERVER_PORT=8080

# Banco de dados PostgreSQL local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/secretariapay_db
SPRING_DATASOURCE_USERNAME=secretariapay_user
SPRING_DATASOURCE_PASSWORD=secretariapay123

# JWT
APP_SECURITY_JWT_SECRET=SecretariaPayBackendJwtSecretKeyForDevelopmentOnlyChangeInProduction2026
APP_SECURITY_JWT_EXPIRATION_MINUTES=1440

# WhatsApp Webhook
SECRETARIAPAY_WHATSAPP_VERIFY_TOKEN=SecretariaPay-dev-token

# WhatsApp Cloud API
# Em desenvolvimento local, mantenha false.
SECRETARIAPAY_WHATSAPP_ENABLED=false

# Preencher apenas quando tivermos os dados reais da Meta
SECRETARIAPAY_WHATSAPP_PHONE_NUMBER_ID=
SECRETARIAPAY_WHATSAPP_ACCESS_TOKEN=
SECRETARIAPAY_WHATSAPP_GRAPH_API_VERSION=v25.0
SECRETARIAPAY_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com


SECRETARIAPAY_EMAIL_ENABLED=true
SECRETARIAPAY_EMAIL_FROM=dcr_pay@imetroangola.com
SECRETARIAPAY_EMAIL_CC=df.oi_pay@imetroangola.com

SECRETARIAPAY_SMS_ENABLED=false
SECRETARIAPAY_SMS_PROVIDER=MOCK
SECRETARIAPAY_SMS_API_URL=
SECRETARIAPAY_SMS_API_TOKEN=