# ==========================================================
# VaiRápido API - Exemplo de variáveis de ambiente
# Copie este arquivo para .env e ajuste localmente.
# Nunca coloque tokens reais no Git.
# ==========================================================

# Servidor
SERVER_PORT=8080

# Banco de dados PostgreSQL local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/vairapido_db
SPRING_DATASOURCE_USERNAME=vairapido_user
SPRING_DATASOURCE_PASSWORD=vairapido123

# JWT
APP_SECURITY_JWT_SECRET=vaiRapidoBackendJwtSecretKeyForDevelopmentOnlyChangeInProduction2026
APP_SECURITY_JWT_EXPIRATION_MINUTES=1440

# WhatsApp Webhook
VAIRAPIDO_WHATSAPP_VERIFY_TOKEN=vairapido-dev-token

# WhatsApp Cloud API
# Em desenvolvimento local, mantenha false.
VAIRAPIDO_WHATSAPP_ENABLED=false

# Preencher apenas quando tivermos os dados reais da Meta
VAIRAPIDO_WHATSAPP_PHONE_NUMBER_ID=
VAIRAPIDO_WHATSAPP_ACCESS_TOKEN=
VAIRAPIDO_WHATSAPP_GRAPH_API_VERSION=v25.0
VAIRAPIDO_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com