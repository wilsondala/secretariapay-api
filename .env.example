# ==========================================================
# SecretáriaPay API — variáveis de ambiente
# Copie para .env.production apenas no servidor.
# Nunca coloque credenciais reais no Git.
# ==========================================================

# Servidor e banco PostgreSQL
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/secretariapay_db
SPRING_DATASOURCE_USERNAME=secretariapay_user
SPRING_DATASOURCE_PASSWORD=

# JWT — obrigatório usar uma chave forte e exclusiva em produção
APP_SECURITY_JWT_SECRET=
APP_SECURITY_JWT_EXPIRATION_MINUTES=1440

# Usuários de teste e recuperação do administrador
# Manter false em produção normal.
SECRETARIAPAY_TEST_USERS_ENABLED=false
SECRETARIAPAY_TEST_USERS_PASSWORD=

# Identidade financeira institucional
SECRETARIAPAY_BUSINESS_COUNTRY=AO
SECRETARIAPAY_BUSINESS_CURRENCY=AOA
SECRETARIAPAY_PUBLIC_API_BASE_URL=https://secretariapay-api.paixaoangola.com
SECRETARIAPAY_OFFICIAL_FALLBACK_EMAIL=dcr_pay@imetroangola.com

# Pagamento público provisório das inscrições
# O piloto permanece desativado por padrão e não deve ser ativado em produção
# sem autorização institucional explícita do IMETRO.
SECRETARIAPAY_ADMISSIONS_PUBLIC_PAYMENT_PILOT_ENABLED=false
# Prazo padrão: 3 dias. Pode ser alterado para 4 sem mudança de código.
SECRETARIAPAY_ADMISSIONS_PUBLIC_PAYMENT_DUE_DAYS=3
SECRETARIAPAY_ADMISSIONS_PUBLIC_PAYMENT_ENVIRONMENT_LABEL=HOMOLOGAÇÃO LOCAL
SECRETARIAPAY_ADMISSIONS_PUBLIC_PAYMENT_PROVIDER=BAI_TRANSFERENCIA_BANCARIA_PILOTO
# Marca automaticamente como desistência somente quando explicitamente ativado.
SECRETARIAPAY_ADMISSIONS_PAYMENT_EXPIRY_ENABLED=false
SECRETARIAPAY_ADMISSIONS_PAYMENT_EXPIRY_CRON=0 15 * * * *

# Dados bancários já utilizados nas guias validadas do projeto.
# Podem ser substituídos por variáveis próprias em cada ambiente.
SECRETARIAPAY_PAYMENT_BANK_NAME=Banco Angolano de Investimento
SECRETARIAPAY_PAYMENT_ACCOUNT_HOLDER=OMNEN INTELENGENDA
SECRETARIAPAY_PAYMENT_IBAN=AO06 0040 0000 6014 4677 1017 1
SECRETARIAPAY_PAYMENT_ACCOUNT_NUMBER=06014467710001
SECRETARIAPAY_PAYMENT_MULTICAIXA_REFERENCE=Multicaixa Express / transferência bancária para a conta AKZ indicada
SECRETARIAPAY_PAYMENT_MOBILE_MONEY_INFO=Unitel Money/Afrimoney quando autorizado pela instituição
SECRETARIAPAY_INSTITUTION_WHATSAPP=+244 991 640 259
SECRETARIAPAY_INSTITUTION_FINANCIAL_EMAIL=secretaria.financeira@imetroangola.com

# WhatsApp Cloud API
SECRETARIAPAY_WHATSAPP_VERIFY_TOKEN=
SECRETARIAPAY_WHATSAPP_ENABLED=false
# Mock exclusivo para homologação local. Exige GRAPH_API_BASE_URL em localhost/127.0.0.1.
SECRETARIAPAY_WHATSAPP_VALIDATION_MOCK_ENABLED=false
SECRETARIAPAY_WHATSAPP_PHONE_NUMBER_ID=
SECRETARIAPAY_WHATSAPP_ACCESS_TOKEN=
SECRETARIAPAY_WHATSAPP_GRAPH_API_VERSION=v25.0
SECRETARIAPAY_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com

# Pagamentos de desenvolvimento
# Deve permanecer false no ambiente institucional do IMETRO.
SECRETARIAPAY_INFINITEPAY_TEST_ENABLED=false

# AppyPay — preencher após homologação das credenciais oficiais
APPYPAY_ENABLED=false
APPYPAY_TOKEN_URL=
APPYPAY_CHARGES_URL=
APPYPAY_CLIENT_ID=
APPYPAY_CLIENT_SECRET=
APPYPAY_RESOURCE=
APPYPAY_PAYMENT_METHOD_GPO=
APPYPAY_PAYMENT_METHOD_REF=
APPYPAY_REFERENCE_ENTITY=

# Notificações por e-mail
SECRETARIAPAY_NOTIFICATIONS_EMAIL_ENABLED=false
SECRETARIAPAY_NOTIFICATIONS_EMAIL_FROM=dcr_pay@imetroangola.com
SECRETARIAPAY_NOTIFICATIONS_EMAIL_CC=df.oi_pay@imetroangola.com
SECRETARIAPAY_NOTIFICATIONS_EMAIL_SENDER_NAME=SecretáriaPay Académico — IMETRO
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# SMS — permanece preparado até contratação de provedor angolano
SECRETARIAPAY_NOTIFICATIONS_SMS_ENABLED=false
SECRETARIAPAY_NOTIFICATIONS_SMS_PROVIDER=MOCK
SECRETARIAPAY_NOTIFICATIONS_SMS_API_URL=
SECRETARIAPAY_NOTIFICATIONS_SMS_API_KEY=
SECRETARIAPAY_NOTIFICATIONS_SMS_SENDER_ID=SecretariaPay
